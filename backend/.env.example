PORT=8787
FRONTEND_ORIGIN=http://localhost:5173

# Closed-group access list (comma-separated emails).
APPROVED_EMAILS=player1@example.com,player2@example.com

# Google OAuth Client ID (from Google Cloud Console).
GOOGLE_CLIENT_ID=

# Admins can edit/delete games.
ADMIN_EMAILS=admin@example.com

# Registration closes this many hours before the game.
REGISTRATION_LEAD_HOURS=24

# Optional push notifications configuration.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Optional secret for manual reminder dispatch endpoint.
REMINDER_SECRET=
